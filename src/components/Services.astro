---
const services = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
    </svg>`,
    label: 'Monitorizare',
    title: 'Monitorizare Energetică',
    desc: 'Vezi exact cât consumi: tensiune, curent, putere, factor de putere și energie, pe fiecare fază, în timp real. Identifici risipa și vârfurile de consum imediat.',
    tags: ['Timp real', 'Pe 3 faze', 'Precizie'],
    color: 'green',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
    </svg>`,
    label: 'Automatizări',
    title: 'Automatizări și Control',
    desc: 'Scenarii care lucrează pentru tine: programare orară, comenzi automate, reacții la senzori și condiții logice — pentru spații tehnice, laboratoare și clădiri.',
    tags: ['Automat', 'Scenarii', 'Control'],
    color: 'cyan',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
    </svg>`,
    label: 'Dashboard-uri',
    title: 'Dashboard-uri și Rapoarte',
    desc: 'Date clare, ușor de citit: grafice în timp real, evoluții pe perioade și rapoarte automate. Primești notificări când un parametru depășește pragul stabilit.',
    tags: ['Grafice', 'Rapoarte', 'Alerte'],
    color: 'amber',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/>
      <line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>
    </svg>`,
    label: 'Infrastructură',
    title: 'Hosting Local & Acces Securizat',
    desc: 'Datele tale rămân la tine, pe infrastructura ta. Acces de la distanță printr-o conexiune criptată, fără IP public și fără să expui rețeaua direct la internet.',
    tags: ['Local', 'Securizat', 'Remote'],
    color: 'green',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/>
      <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1"/>
    </svg>`,
    label: 'Senzori',
    title: 'Integrare Senzori',
    desc: 'Adăugăm senzori pentru temperatură, umiditate, consum, mișcare sau contact. Totul comunică local și se integrează unitar în același sistem de monitorizare.',
    tags: ['Senzori', 'Wireless', 'Extensibil'],
    color: 'cyan',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
    </svg>`,
    label: 'Mentenanță',
    title: 'Mentenanță și Extindere',
    desc: 'Suport tehnic continuu, actualizări și extindere cu noi senzori sau puncte de măsurare, pe măsură ce nevoile cresc. Documentație și instruire pentru echipa ta.',
    tags: ['Suport', 'Actualizări', 'Scalare'],
    color: 'amber',
  },
];
---

<section id="servicii" class="services-section">
  <div class="services-bg-glow"></div>

  <!-- Circuite cu „curent" care curge -->
  <svg class="svc-circuit" viewBox="0 0 1200 320" preserveAspectRatio="none" fill="none" aria-hidden="true">
    <path d="M0 70 H280 V180 H560 V50 H840 V230 H1200" stroke="rgba(16,185,129,0.16)" stroke-width="1.4" class="flow-dash"/>
    <path d="M0 250 H180 V120 H470 V270 H760 V90 H1040 V210 H1200" stroke="rgba(6,182,212,0.14)" stroke-width="1.4" class="flow-dash-slow"/>
    <circle cx="280" cy="70" r="3.5" fill="#34d399" class="blink"/>
    <circle cx="560" cy="50" r="3.5" fill="#34d399" class="blink" style="animation-delay:-0.8s"/>
    <circle cx="840" cy="230" r="3.5" fill="#34d399" class="blink" style="animation-delay:-1.6s"/>
    <circle cx="470" cy="270" r="3" fill="#06b6d4" class="blink" style="animation-delay:-1.2s"/>
    <circle cx="760" cy="90" r="3" fill="#06b6d4" class="blink" style="animation-delay:-0.4s"/>
  </svg>

  <div class="container">
    <div class="services-header" data-reveal>
      <p class="section-label">Ce oferim</p>
      <h2 class="section-title">Soluții complete,<br>de la măsurare la decizie</h2>
      <p class="section-subtitle">
        De la instalare și măsurare, până la vizualizare, alerte și mentenanță —
        ne ocupăm de tot, ca tu să ai control deplin asupra consumului.
      </p>
    </div>

    <div class="services-grid">
      {services.map((s, i) => (
        <article class={`service-card card-${s.color}`} data-reveal="scale" data-delay={(i % 3) * 90}>
          <div class="card-top">
            <div class={`card-icon icon-${s.color}`} set:html={s.icon} />
            <span class={`card-label lbl-${s.color}`}>{s.label}</span>
          </div>
          <h3 class="card-title">{s.title}</h3>
          <p class="card-desc">{s.desc}</p>
          <div class="card-tags">
            {s.tags.map(t => (
              <span class={`tbadge ${s.color === 'amber' ? 'amber' : s.color === 'cyan' ? '' : 'green'}`}>{t}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    background: rgba(11,24,38,0.62);
    position: relative;
    overflow: hidden;
  }

  .services-bg-glow {
    position: absolute;
    top: 50%; right: -10%;
    width: 50%; height: 70%;
    transform: translateY(-50%);
    background: radial-gradient(ellipse,
      rgba(6,182,212,0.04) 0%,
      transparent 65%);
    pointer-events: none;
  }

  .svc-circuit {
    position: absolute;
    left: 0; right: 0; top: 8%;
    width: 100%; height: 70%;
    z-index: 0;
    pointer-events: none;
  }
  .services-section .container { position: relative; z-index: 1; }

  /* iconițe care plutesc ușor (decalate) */
  .card-icon { animation: floatY 7s ease-in-out infinite; }
  .service-card:nth-child(3n+2) .card-icon { animation-delay: -2.3s; }
  .service-card:nth-child(3n)   .card-icon { animation-delay: -4.6s; }

  .services-header {
    margin-bottom: 64px;
    max-width: 680px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* Cards — premium */
  .service-card {
    background:
      linear-gradient(180deg, rgba(255,255,255,0.022), transparent 38%),
      var(--card);
    border-radius: var(--radius-lg);
    padding: 26px 24px 22px;
    border: 1px solid var(--border);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    overflow: hidden;
  }

  /* glow radial care urmează cardul la hover */
  /* conținutul deasupra glow-ului */
  .service-card > * { position: relative; z-index: 1; }

  .service-card::after {
    content: '';
    position: absolute;
    top: -40%; right: -30%;
    width: 220px; height: 220px;
    border-radius: 50%;
    opacity: 0;
    filter: blur(50px);
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: 0;
  }
  .card-green::after { background: rgba(16,185,129,0.16); }
  .card-cyan::after  { background: rgba(6,182,212,0.16); }
  .card-amber::after { background: rgba(245,158,11,0.14); }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  .card-green::before { background: linear-gradient(90deg, var(--green), transparent); }
  .card-cyan::before  { background: linear-gradient(90deg, var(--cyan), transparent); }
  .card-amber::before { background: linear-gradient(90deg, var(--amber), transparent); }

  .service-card:hover {
    border-color: var(--border-med);
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }
  .card-green:hover { box-shadow: var(--shadow-lg), var(--glow-green); }
  .card-cyan:hover  { box-shadow: var(--shadow-lg), var(--glow-cyan); }

  .service-card:hover::before { opacity: 1; }
  .service-card:hover::after { opacity: 1; }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-icon {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius);
    flex-shrink: 0;
  }

  .card-icon svg { width: 22px; height: 22px; }

  .icon-green { color: var(--green); background: var(--green-dim); }
  .icon-cyan  { color: var(--cyan);  background: var(--cyan-dim); }
  .icon-amber { color: var(--amber); background: var(--amber-dim); }

  .card-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 9px;
    border-radius: 3px;
  }

  .lbl-green { color: var(--green);  background: var(--green-dim); }
  .lbl-cyan  { color: var(--cyan);   background: var(--cyan-dim); }
  .lbl-amber { color: var(--amber);  background: var(--amber-dim); }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.68;
    flex: 1;
  }

  .card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; gap: 14px; }
    .services-header { margin-bottom: 40px; }
  }
</style>
