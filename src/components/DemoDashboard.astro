---
// ── EB104 Lab · Janitza Power Quality Dashboard ──
// Dashboard full-screen care consumă API-ul local: GET /api/janitza/summary?range=...
// Datele reale: tensiuni / curenți / putere (live + istoric).
// Placeholder (până extindem API-ul): energie kWh pe oră/zi/lună/an + tabelul de rapoarte.

// Geometrie gauge (270°, gap jos) — calculăm traseul „track" pe server, identic cu clientul.
function polarToCartesian(cx, cy, r, angleDeg) {
  const a = ((angleDeg - 90) * Math.PI) / 180;
  return { x: cx + r * Math.cos(a), y: cy + r * Math.sin(a) };
}
function describeArc(cx, cy, r, startAngle, endAngle) {
  const start = polarToCartesian(cx, cy, r, endAngle);
  const end = polarToCartesian(cx, cy, r, startAngle);
  const large = endAngle - startAngle <= 180 ? '0' : '1';
  return ['M', start.x.toFixed(2), start.y.toFixed(2), 'A', r, r, 0, large, 0, end.x.toFixed(2), end.y.toFixed(2)].join(' ');
}
const GAUGE_TRACK = describeArc(60, 60, 44, 225, 495);

// Secțiunile din meniul lateral, grupate pe domenii.
//  - „domain" = sistem de monitorizare (preview parametri până la integrare)
//  - „info"   = zonă informativă (rezultate), nu integrare live în site
const views = [
  {
    id: 'energy', group: 'Monitorizare', kind: 'energy', active: true,
    label: 'Calitate energie',
    title: 'Monitorizare calitate energie', sub: 'Analizor de rețea · tensiuni, curenți, putere',
    icon: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
  },
  {
    id: 'airclimate', group: 'Monitorizare', kind: 'domain',
    label: 'Calitate aer & climatizare',
    title: 'Calitate aer & climatizare confort', sub: 'Aer, temperatură, umiditate, ventilație',
    icon: '<path d="M3 8h13a3 3 0 1 0-3-3"/><path d="M3 12h17a3 3 0 1 1-3 3"/><path d="M3 16h9a3 3 0 1 1-3 3"/>',
  },
  {
    id: 'solar', group: 'Monitorizare', kind: 'domain',
    label: 'Fotovoltaice & invertoare',
    title: 'Fotovoltaice & invertoare', sub: 'Producție, parametri invertor, flux luminos',
    icon: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>',
  },
  {
    id: 'automations', group: 'Informativ', kind: 'info',
    label: 'Automatizări',
    title: 'Automatizări', sub: 'Rezultate și stare scenarii',
    icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  },
  {
    id: 'alerts', group: 'Informativ', kind: 'info',
    label: 'Alerte',
    title: 'Alerte', sub: 'Rezultate, alarme și evenimente',
    icon: '<path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/>',
  },
];

// Preview-ul parametrilor pentru domeniile pregătite (afișați ca „în pregătire").
const previewTiles = {
  airclimate: [
    { label: 'Temperatură', unit: '°C' }, { label: 'Umiditate', unit: '%' }, { label: 'CO₂', unit: 'ppm' },
    { label: 'Particule PM2.5', unit: 'µg/m³' }, { label: 'COV', unit: 'index' }, { label: 'Ventilație', unit: '%' },
  ],
  solar: [
    { label: 'Putere AC', unit: 'W' }, { label: 'Energie azi', unit: 'kWh' }, { label: 'Tensiune DC', unit: 'V' },
    { label: 'Curent DC', unit: 'A' }, { label: 'Randament invertor', unit: '%' }, { label: 'Flux luminos', unit: 'lux' },
  ],
};

// Rânduri tabel — decuplate de grafic. Surse fixe: 24h (fin) pentru oră/azi,
// 7d pentru ieri/săptămână. Rămân stabile indiferent de intervalul graficului.
const reportRows = [
  { key: 'h1', period: 'Ultima oră' },
  { key: 'today', period: 'Astăzi' },
  { key: 'yest', period: 'Ieri' },
  { key: 'd7', period: 'Ultimele 7 zile' },
];
---

<div class="dash" data-track={GAUGE_TRACK}>
  <!-- ───────── Sidebar ───────── -->
  <aside class="dash-sidebar">
    <a class="brand" href="/" title="Înapoi la site">
      <span class="brand-mark">
        <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="28" height="28" rx="6" fill="#0d1e30"/>
          <polygon points="17,3 10,15 15,15 11,25 19,13 14,13" fill="#10b981"/>
        </svg>
      </span>
      <span class="brand-text">
        <strong>EB104 Lab</strong>
        <small>Monitorizare energetică</small>
      </span>
    </a>

    <nav class="side-nav">
      {views.map((item, idx) => (
        <>
          {(idx === 0 || views[idx - 1].group !== item.group) && (
            <span class="side-group">{item.group}</span>
          )}
          <button
            type="button"
            class={`side-link${item.active ? ' active' : ''}`}
            data-view={item.id}
            data-title={item.title}
            data-sub={item.sub}
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
            <span>{item.label}</span>
          </button>
        </>
      ))}
    </nav>

    <div class="side-foot">
      <div class="side-source">
        <span class="src-label">Sursă date</span>
        <span class="src-value">Janitza · analizor rețea</span>
      </div>
      <div class="side-status" id="side-status">
        <span class="pulse-dot"></span>
        <span id="side-status-text">Conectare…</span>
      </div>
    </div>
  </aside>

  <!-- ───────── Main ───────── -->
  <div class="dash-main">
    <!-- Topbar -->
    <header class="dash-topbar">
      <div class="top-left">
        <a href="/" class="back-btn" title="Înapoi la site">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
          </svg>
          <span>Înapoi la site</span>
        </a>
        <div class="top-title">
          <h1 id="view-title">Monitorizare calitate energie</h1>
          <p id="view-sub">Analizor de rețea · tensiuni, curenți, putere</p>
        </div>
      </div>

      <div class="top-controls" id="top-controls">
        <div class="range-select" role="tablist" aria-label="Interval istoric">
          <button type="button" data-range="1h">1h</button>
          <button type="button" data-range="6h">6h</button>
          <button type="button" class="active" data-range="12h">12h</button>
          <button type="button" data-range="24h">24h</button>
          <button type="button" data-range="7d">7 zile</button>
        </div>
        <div class="top-live" id="top-live">
          <span class="pulse-dot"></span>
          <span id="top-live-text">Live</span>
          <span class="top-updated" id="top-updated">--:--:--</span>
        </div>
      </div>
    </header>

    <!-- Scrollable dashboard area -->
    <div class="dash-scroll">
      <!-- ░░░ Secțiunea: Monitorizare calitate energie ░░░ -->
      <section class="view active" id="view-energy" data-view-panel>
      <!-- KPI: putere pe faze + total -->
      <div class="grid-row kpi-row" data-anim>
        <article class="card kpi kpi-l1">
          <div class="kpi-head"><span class="dot dot-l1"></span>Putere L1</div>
          <div class="kpi-value"><strong id="pw-l1">--</strong><span>W</span></div>
          <div class="kpi-sub" id="pw-l1-sub">faza 1</div>
        </article>
        <article class="card kpi kpi-l2">
          <div class="kpi-head"><span class="dot dot-l2"></span>Putere L2</div>
          <div class="kpi-value"><strong id="pw-l2">--</strong><span>W</span></div>
          <div class="kpi-sub" id="pw-l2-sub">faza 2</div>
        </article>
        <article class="card kpi kpi-l3">
          <div class="kpi-head"><span class="dot dot-l3"></span>Putere L3</div>
          <div class="kpi-value"><strong id="pw-l3">--</strong><span>W</span></div>
          <div class="kpi-sub" id="pw-l3-sub">faza 3</div>
        </article>
        <article class="card kpi kpi-total">
          <div class="kpi-head"><span class="dot dot-total"></span>Putere totală</div>
          <div class="kpi-value"><strong id="pw-total">--</strong><span>W</span></div>
          <div class="kpi-sub" id="pw-total-sub">însumat pe 3 faze</div>
        </article>
      </div>

      <!-- Chart + NOW -->
      <div class="grid-row main-row" data-anim>
        <article class="card chart-card">
          <div class="card-head">
            <div>
              <span class="card-kicker">Istoric · <span id="chart-range">12h</span></span>
              <h2 id="chart-title">Tensiuni pe faze</h2>
            </div>
            <div class="chart-tabs" role="tablist" aria-label="Serie afișată">
              <button type="button" class="active" data-chart="voltage">U · Tensiuni</button>
              <button type="button" data-chart="current">I · Curenți</button>
              <button type="button" data-chart="power">P · Putere</button>
            </div>
          </div>

          <div class="chart-pending" id="chart-pending" hidden>
            <span class="pulse-dot"></span>
            Se încarcă istoricul…
          </div>
          <svg id="chart" class="chart-svg" viewBox="0 0 1000 360" role="img" aria-label="Grafic istoric parametri electrici">
            <defs>
              <linearGradient id="areaFill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#10b981" stop-opacity="0.16" />
                <stop offset="1" stop-color="#10b981" stop-opacity="0" />
              </linearGradient>
            </defs>
            <g class="c-grid"></g>
            <g class="c-ylabels"></g>
            <g class="c-xlabels"></g>
            <path id="c-area" class="c-area" d=""></path>
            <polyline id="c-a" class="c-line c-a" points=""></polyline>
            <polyline id="c-b" class="c-line c-b" points=""></polyline>
            <polyline id="c-c" class="c-line c-c" points=""></polyline>
          </svg>
          <div class="chart-foot">
            <div class="chart-legend" id="chart-legend"></div>
            <span class="data-quality" id="data-quality" title="Valori valide după filtrarea valorilor aberante">
              <span class="dq-dot"></span>Calitate date: <b id="dq-pct">—</b><span id="dq-spikes"></span>
            </span>
          </div>
        </article>

        <article class="card now-card">
          <div class="card-head">
            <span class="card-kicker">ACUM</span>
            <span class="now-state" id="now-state"><span class="pulse-dot"></span>timp real</span>
          </div>
          <div class="now-power">
            <strong id="now-total">--</strong>
            <span>W</span>
          </div>
          <div class="now-label">Putere activă totală</div>

          <div class="now-kpis">
            <div class="nk-caption">Pe intervalul afișat pe grafic</div>
            <div class="nk">
              <span class="nk-label">Consum · <b class="nk-range" id="rng-e">—</b> <i class="est">est.</i></span>
              <span class="nk-val" id="kpi-energy">—</span>
            </div>
            <div class="nk">
              <span class="nk-label">Cost · <b class="nk-range" id="rng-c">—</b> <i class="est">est.</i></span>
              <span class="nk-val" id="kpi-cost">—</span>
            </div>
            <div class="nk">
              <span class="nk-label">Vârf putere · <b class="nk-range" id="rng-p">—</b></span>
              <span class="nk-val" id="kpi-peak">—</span>
            </div>
            <div class="nk">
              <span class="nk-label">Fază dominantă</span>
              <span class="nk-val" id="kpi-domphase">—</span>
            </div>
            <div class="nk">
              <span class="nk-label">Dezechilibru faze</span>
              <span class="nk-val" id="kpi-unbalance">—</span>
            </div>
          </div>
        </article>
      </div>

      <!-- Gauges tensiuni + curenți -->
      <div class="grid-row gauge-row" data-anim>
        <article class="card gauge-card">
          <div class="card-head"><div><span class="card-kicker">Tensiuni</span><h2>Fază–nul (0–300 V)</h2></div></div>
          <div class="gauges">
            <div class="gauge-wrap">
              <svg class="gauge" viewBox="0 0 120 120">
                <path class="gauge-track" d={GAUGE_TRACK} />
                <path class="gauge-value gv-l1" id="g-v-l1" d="" />
                <text class="gauge-num" id="g-t-l1" x="60" y="60" text-anchor="middle">--</text>
                <text class="gauge-unit" x="60" y="78" text-anchor="middle">V · L1</text>
              </svg>
            </div>
            <div class="gauge-wrap">
              <svg class="gauge" viewBox="0 0 120 120">
                <path class="gauge-track" d={GAUGE_TRACK} />
                <path class="gauge-value gv-l2" id="g-v-l2" d="" />
                <text class="gauge-num" id="g-t-l2" x="60" y="60" text-anchor="middle">--</text>
                <text class="gauge-unit" x="60" y="78" text-anchor="middle">V · L2</text>
              </svg>
            </div>
            <div class="gauge-wrap">
              <svg class="gauge" viewBox="0 0 120 120">
                <path class="gauge-track" d={GAUGE_TRACK} />
                <path class="gauge-value gv-l3" id="g-v-l3" d="" />
                <text class="gauge-num" id="g-t-l3" x="60" y="60" text-anchor="middle">--</text>
                <text class="gauge-unit" x="60" y="78" text-anchor="middle">V · L3</text>
              </svg>
            </div>
          </div>
        </article>

        <div class="right-stack">
          <article class="card current-card">
            <div class="card-head"><div><span class="card-kicker">Curenți</span><h2>Pe fază (A)</h2></div></div>
            <div class="cur-list">
              <div class="cur-row"><span class="dot dot-l1"></span><span class="cur-name">L1</span><span class="cur-bar"><i id="cb-l1"></i></span><strong id="cur-l1">--</strong><small>A</small></div>
              <div class="cur-row"><span class="dot dot-l2"></span><span class="cur-name">L2</span><span class="cur-bar"><i id="cb-l2"></i></span><strong id="cur-l2">--</strong><small>A</small></div>
              <div class="cur-row"><span class="dot dot-l3"></span><span class="cur-name">L3</span><span class="cur-bar"><i id="cb-l3"></i></span><strong id="cur-l3">--</strong><small>A</small></div>
            </div>
          </article>

          <article class="card anomaly-card">
            <div class="card-head"><div><span class="card-kicker">Diagnoză</span><h2>Stare parametri</h2></div></div>
            <ul class="anomaly-list">
              <li><span class="an-name">Tensiune</span><span class="an-badge" id="an-voltage">—</span></li>
              <li><span class="an-name">Curent</span><span class="an-badge" id="an-current">—</span></li>
              <li><span class="an-name">Echilibru faze</span><span class="an-badge" id="an-balance">—</span></li>
              <li><span class="an-name">Citiri aberante</span><span class="an-badge" id="an-spikes">—</span></li>
            </ul>
          </article>
        </div>
      </div>

      <!-- Tabel rapoarte -->
      <div class="grid-row" data-anim>
        <article class="card table-card">
          <div class="card-head">
            <div><span class="card-kicker">Rapoarte</span><h2>Consum &amp; energie</h2></div>
            <span class="table-note">Estimat din puterea activă · fereastră 24h (independent de grafic)</span>
          </div>
          <div class="table-scroll">
            <table class="report-table">
              <thead>
                <tr><th>Perioadă</th><th>Energie</th><th>Vârf putere</th><th>Medie</th><th>Status</th></tr>
              </thead>
              <tbody>
                {reportRows.map(r => (
                  <tr>
                    <td id={`rep-${r.key}-period`}>{r.period}</td>
                    <td class="mono" id={`rep-${r.key}-e`}>—</td>
                    <td class="mono" id={`rep-${r.key}-p`}>—</td>
                    <td class="mono" id={`rep-${r.key}-a`}>—</td>
                    <td><span class="rep-badge rep-pending" id={`rep-${r.key}-s`}>în pregătire</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </article>
      </div>
      </section>

      <!-- ░░░ Secțiuni pregătite ░░░ -->
      {views.filter(v => v.id !== 'energy').map(v => (
        <section class="view" id={`view-${v.id}`} data-view-panel hidden>
          <div class="ph-hero" data-anim>
            <div class={`ph-mark ph-mark-${v.id}`}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={v.icon} />
            </div>
            <div class="ph-hero-text">
              <span class="ph-badge"><span class="pulse-dot"></span>{v.kind === 'info' ? 'Zonă informativă' : 'Sistem în pregătire'}</span>
              <h2>{v.title}</h2>
              <p>
                {v.kind === 'info'
                  ? `${v.sub}. Aici vor fi afișate rezultatele — fără integrare live în site.`
                  : `${v.sub}. Integrarea datelor este în curs — structura de mai jos arată ce vom monitoriza.`}
              </p>
            </div>
          </div>

          {v.kind === 'domain' && (
            <div class="ph-grid" data-anim>
              {(previewTiles[v.id] || []).map(t => (
                <article class="card ph-tile">
                  <span class="ph-tile-label">{t.label}</span>
                  <span class="ph-tile-val">—</span>
                  <span class="ph-tile-foot">
                    {t.unit && <em class="ph-unit">{t.unit}</em>}
                    <span class="ph-pending">în pregătire</span>
                  </span>
                </article>
              ))}
            </div>
          )}

          {v.kind === 'info' && (
            <div class="ph-results card" data-anim>
              <svg class="ph-results-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="3" width="16" height="18" rx="2"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="13" y2="16"/>
              </svg>
              <p class="ph-results-title">Niciun rezultat încă</p>
              <p class="ph-results-sub">Rezultatele {v.id === 'alerts' ? 'alertelor și evenimentelor' : 'automatizărilor'} vor apărea aici.</p>
            </div>
          )}
        </section>
      ))}
    </div>
  </div>
</div>

<script is:inline>
(function () {
  // ── Config ──
  var API = '/api/janitza/summary';
  var REFRESH_MS = 5000;
  var range = '12h';
  var activeChart = 'voltage';
  var dataCache = null;
  var timer = null;

  // ── Filtrare frontend (protecție suplimentară față de backend) ──
  var LIMITS = { voltage: [0, 300], current: [0, 100], power: [-50000, 50000] };
  function kindOf(key) {
    if (key.indexOf('voltage') === 0) return 'voltage';
    if (key.indexOf('current') === 0) return 'current';
    return 'power';
  }
  function clean(key, val) {
    var v = Number(val);
    if (!isFinite(v)) return null;
    var b = LIMITS[kindOf(key)];
    if (v < b[0] || v > b[1]) return null;
    return v;
  }
  function fmt(v, d) {
    if (v === null || v === undefined || !isFinite(Number(v))) return '--';
    return Number(v).toLocaleString('ro-RO', { minimumFractionDigits: d, maximumFractionDigits: d });
  }
  function $(id) { return document.getElementById(id); }
  function setText(id, v, d) { var el = $(id); if (el) el.textContent = fmt(v, d); }

  // ── Parametri business (ușor de modificat) ──
  var TARIFF_RON_PER_KWH = 0.85; // tarif energie electrică
  // Praguri anomaly detection
  var TH = {
    voltWarnMin: 210, voltWarnMax: 240,   // avertisment tensiune
    voltCritMin: 195, voltCritMax: 255,   // critic tensiune
    currWarn: 80, currCrit: 95,           // curent (A)
    unbalanceWarn: 60                     // dezechilibru curent (%)
  };

  function num(v) { var n = Number(v); return isFinite(n) ? n : null; }
  function localMidnight() { var d = new Date(); d.setHours(0, 0, 0, 0); return d.getTime(); }

  // Energie (kWh) prin integrare trapezoidală a puterii totale peste TOT intervalul
  // afișat pe grafic (nu doar „azi") -> mereu corect, indiferent de range.
  function energyKwh(points) {
    var pts = points.filter(function (p) { return clean('power_total', p.power_total) !== null; });
    if (pts.length < 2) return null;
    var wh = 0;
    for (var i = 1; i < pts.length; i++) {
      var t0 = new Date(pts[i - 1].time).getTime(), t1 = new Date(pts[i].time).getTime();
      var p0 = clean('power_total', pts[i - 1].power_total), p1 = clean('power_total', pts[i].power_total);
      wh += ((p0 + p1) / 2) * ((t1 - t0) / 3600000);
    }
    return wh / 1000;
  }
  function peakW(points) {
    var peak = null;
    points.forEach(function (p) {
      var v = clean('power_total', p.power_total);
      if (v !== null && (peak === null || v > peak)) peak = v;
    });
    return peak;
  }
  // Dezechilibru curent (%) = (Imax - Imin) / Imax * 100
  function currentUnbalance(c1, c2, c3) {
    var vals = [c1, c2, c3].map(num).filter(function (v) { return v !== null; });
    if (vals.length < 2) return null;
    var mx = Math.max.apply(null, vals), mn = Math.min.apply(null, vals);
    return mx > 0 ? ((mx - mn) / mx) * 100 : 0;
  }
  function dominantPhase(p1, p2, p3) {
    var arr = [['L1', num(p1)], ['L2', num(p2)], ['L3', num(p3)]].filter(function (x) { return x[1] !== null; });
    if (!arr.length) return null;
    arr.sort(function (a, b) { return b[1] - a[1]; });
    return arr[0][0];
  }
  function setBadge(id, level) {
    var el = $(id); if (!el) return;
    var label = level === 'crit' ? 'Critic' : (level === 'warn' ? 'Atenție' : 'Normal');
    el.textContent = label;
    el.className = 'an-badge an-' + (level || 'ok');
  }

  // ── KPI-uri business (consum/cost/vârf = pe intervalul afișat pe grafic) ──
  function updateBusiness(d) {
    var points = (d && d.history) || [];
    var live = (d && d.live) || {};
    var p = live.power || {}, i = live.current || {};

    // eticheta intervalului lângă consum/cost/vârf
    ['rng-e', 'rng-c', 'rng-p'].forEach(function (id) { var el = $(id); if (el) el.textContent = range; });

    var energy = energyKwh(points);
    $('kpi-energy').textContent = energy === null ? '—' : fmt(energy, 2) + ' kWh';
    $('kpi-cost').textContent = energy === null ? '—' : fmt(energy * TARIFF_RON_PER_KWH, 2) + ' RON';

    var peak = peakW(points);
    $('kpi-peak').textContent = peak === null ? '—' : fmt(peak, 0) + ' W';

    var dom = dominantPhase(p.l1, p.l2, p.l3);
    $('kpi-domphase').textContent = dom || '—';

    var unb = currentUnbalance(i.l1, i.l2, i.l3);
    $('kpi-unbalance').textContent = unb === null ? '—' : fmt(unb, 0) + ' %';
  }

  // ── Data quality (sursă: filtrarea de pe server) ──
  function updateDataQuality(d) {
    var q = d && d.quality;
    var pctEl = $('dq-pct'), spEl = $('dq-spikes');
    if (!q) { if (pctEl) pctEl.textContent = '—'; if (spEl) spEl.textContent = ''; return; }
    if (pctEl) pctEl.textContent = fmt(q.validPct, 1) + '%';
    if (spEl) spEl.textContent = ' · ' + (q.spikes || 0) + ' valori aberante filtrate';
  }

  // ── Anomaly detection (din valorile live) ──
  function updateAnomaly(d) {
    var live = (d && d.live) || {};
    var u = live.voltage || {}, i = live.current || {};
    var q = d && d.quality;

    var volts = [u.l1, u.l2, u.l3].map(function (k) { return clean('voltage', k); }).filter(function (v) { return v !== null; });
    var vLevel = 'ok';
    volts.forEach(function (v) {
      if (v < TH.voltCritMin || v > TH.voltCritMax) vLevel = 'crit';
      else if ((v < TH.voltWarnMin || v > TH.voltWarnMax) && vLevel !== 'crit') vLevel = 'warn';
    });
    setBadge('an-voltage', volts.length ? vLevel : null);

    var curs = [i.l1, i.l2, i.l3].map(function (k) { return clean('current', k); }).filter(function (v) { return v !== null; });
    var cLevel = 'ok';
    curs.forEach(function (v) {
      if (v > TH.currCrit) cLevel = 'crit';
      else if (v > TH.currWarn && cLevel !== 'crit') cLevel = 'warn';
    });
    setBadge('an-current', curs.length ? cLevel : null);

    var unb = currentUnbalance(i.l1, i.l2, i.l3);
    setBadge('an-balance', unb === null ? null : (unb > TH.unbalanceWarn ? 'warn' : 'ok'));

    setBadge('an-spikes', q ? (q.spikes > 0 ? 'warn' : 'ok') : null);
  }

  // ── Tabel rapoarte (din history; energie = integrare puterii totale) ──
  function periodStats(points, start, end) {
    var pts = points.filter(function (p) {
      if (clean('power_total', p.power_total) === null) return false;
      var t = new Date(p.time).getTime();
      return t >= start && t <= end;
    });
    if (pts.length < 2) return null;
    var wh = 0, peak = -Infinity, sum = 0;
    for (var i = 0; i < pts.length; i++) {
      var v = clean('power_total', pts[i].power_total);
      if (v > peak) peak = v;
      sum += v;
      if (i > 0) {
        var t0 = new Date(pts[i - 1].time).getTime(), t1 = new Date(pts[i].time).getTime();
        var v0 = clean('power_total', pts[i - 1].power_total);
        wh += ((v0 + v) / 2) * ((t1 - t0) / 3600000);
      }
    }
    return { kwh: wh / 1000, peak: peak, avg: sum / pts.length, covStart: new Date(pts[0].time).getTime() };
  }

  function setReportRow(key, stats, start, end) {
    var eEl = $('rep-' + key + '-e'), pEl = $('rep-' + key + '-p'), aEl = $('rep-' + key + '-a'), sEl = $('rep-' + key + '-s');
    if (!stats) {
      if (eEl) eEl.textContent = '—'; if (pEl) pEl.textContent = '—'; if (aEl) aEl.textContent = '—';
      if (sEl) { sEl.textContent = 'în pregătire'; sEl.className = 'rep-badge rep-pending'; }
      return;
    }
    if (eEl) eEl.textContent = fmt(stats.kwh, 2) + ' kWh';
    if (pEl) pEl.textContent = fmt(stats.peak, 0) + ' W';
    if (aEl) aEl.textContent = fmt(stats.avg, 0) + ' W';
    // parțial doar dacă lipsește o porțiune reală din perioadă (nu un simplu
    // decalaj de un bucket); toleranță = max(20% din fereastră, 12 min)
    var partial = (stats.covStart - start) > Math.max((end - start) * 0.2, 720000);
    if (sEl) {
      sEl.textContent = partial ? 'parțial' : 'calculat';
      sEl.className = 'rep-badge ' + (partial ? 'rep-partial' : 'rep-ok');
    }
  }

  // Tabelul are propriile surse fixe (independent de graficul selectat):
  //  - 24h (rezoluție fină) pentru „Ultima oră" și „Astăzi"
  //  - 7d pentru „Ieri" și „Ultimele 7 zile"
  function fetchHistory(rng) {
    return fetch(API + '?range=' + rng, { cache: 'no-store' })
      .then(function (r) { return r.ok ? r.json() : null; })
      .catch(function () { return null; });
  }
  function loadReports() {
    var now = Date.now(), mid = localMidnight(), DAY = 86400000;
    fetchHistory('24h').then(function (d) {
      if (!d) return;
      var p = d.history || [];
      setReportRow('h1', periodStats(p, now - 3600000, now), now - 3600000, now);
      setReportRow('today', periodStats(p, mid, now), mid, now);
    });
    fetchHistory('7d').then(function (d) {
      if (!d) return; // 7d încă se calculează -> rândurile rămân „în pregătire"
      var p = d.history || [];
      setReportRow('yest', periodStats(p, mid - DAY, mid), mid - DAY, mid);
      setReportRow('d7', periodStats(p, now - 7 * DAY, now), now - 7 * DAY, now);
    });
  }

  // ── Chart ──
  var chartConfig = {
    voltage: { title: 'Tensiuni pe faze', unit: 'V', keys: ['voltage_l1', 'voltage_l2', 'voltage_l3'], labels: ['L1-N', 'L2-N', 'L3-N'], digits: 1 },
    current: { title: 'Curenți pe faze', unit: 'A', keys: ['current_l1', 'current_l2', 'current_l3'], labels: ['L1', 'L2', 'L3'], digits: 2 },
    power:   { title: 'Putere activă', unit: 'W', keys: ['power_l1', 'power_l2', 'power_l3'], labels: ['P L1', 'P L2', 'P L3'], digits: 0 }
  };
  var SERIES_COLORS = ['#34d399', '#06b6d4', '#f59e0b'];
  var PLOT = { left: 60, right: 24, top: 26, bottom: 46, vw: 1000, vh: 360 };

  function valueRange(points, keys) {
    var vals = [];
    points.forEach(function (p) {
      keys.forEach(function (k) {
        var v = clean(k, p[k]);
        if (v !== null) vals.push(v);
      });
    });
    if (!vals.length) return { min: 0, max: 1 };
    var min = Math.min.apply(null, vals), max = Math.max.apply(null, vals);
    if (min === max) { min -= 1; max += 1; }
    var pad = (max - min) * 0.12;
    return { min: min - pad, max: max + pad };
  }
  function xy(index, total, value, min, max) {
    var w = PLOT.vw - PLOT.left - PLOT.right, h = PLOT.vh - PLOT.top - PLOT.bottom;
    var x = PLOT.left + (total > 1 ? index / (total - 1) : 0) * w;
    var y = PLOT.top + (1 - (value - min) / (max - min)) * h;
    return [x, y];
  }
  function makePoints(points, key, min, max) {
    if (points.length < 2) return '';
    var out = [];
    points.forEach(function (p, i) {
      var v = clean(key, p[key]);
      if (v === null) return;
      var c = xy(i, points.length, v, min, max);
      out.push(c[0].toFixed(1) + ',' + c[1].toFixed(1));
    });
    return out.length >= 2 ? out.join(' ') : '';
  }
  function makeArea(points, key, min, max) {
    if (points.length < 2) return '';
    var base = PLOT.vh - PLOT.bottom, pts = [];
    points.forEach(function (p, i) {
      var v = clean(key, p[key]);
      if (v === null) return;
      pts.push(xy(i, points.length, v, min, max));
    });
    if (pts.length < 2) return '';
    var d = 'M' + pts[0][0].toFixed(1) + ',' + base.toFixed(1);
    pts.forEach(function (c) { d += ' L' + c[0].toFixed(1) + ',' + c[1].toFixed(1); });
    d += ' L' + pts[pts.length - 1][0].toFixed(1) + ',' + base.toFixed(1) + ' Z';
    return d;
  }
  function drawGrid(min, max, unit) {
    var grid = document.querySelector('#chart .c-grid');
    var ylab = document.querySelector('#chart .c-ylabels');
    if (!grid || !ylab) return;
    var L = PLOT.left, T = PLOT.top, W = PLOT.vw - PLOT.left - PLOT.right, H = PLOT.vh - PLOT.top - PLOT.bottom;
    var GRID = 'stroke="rgba(122,155,184,0.12)" stroke-width="1"';
    var AXIS = 'stroke="rgba(180,202,224,0.55)" stroke-width="1.5"';
    var TXT = 'fill="#8fb0cc" font-size="12" font-family="Consolas, monospace"';
    var g = '', l = '';
    for (var i = 0; i <= 4; i++) {
      var y = T + (i / 4) * H, val = max - (i / 4) * (max - min);
      g += '<line ' + GRID + ' x1="' + L + '" y1="' + y + '" x2="' + (L + W) + '" y2="' + y + '" />';
      l += '<text ' + TXT + ' x="' + (L - 9) + '" y="' + (y + 4) + '" text-anchor="end">' + fmt(val, unit === 'A' ? 1 : 0) + '</text>';
    }
    for (var j = 0; j <= 6; j++) {
      var x = L + (j / 6) * W;
      g += '<line ' + GRID + ' x1="' + x + '" y1="' + T + '" x2="' + x + '" y2="' + (T + H) + '" />';
    }
    g += '<line ' + AXIS + ' x1="' + L + '" y1="' + T + '" x2="' + L + '" y2="' + (T + H) + '" />';
    g += '<line ' + AXIS + ' x1="' + L + '" y1="' + (T + H) + '" x2="' + (L + W) + '" y2="' + (T + H) + '" />';
    grid.innerHTML = g;
    ylab.innerHTML = l + '<text ' + TXT + ' x="16" y="20" text-anchor="middle">' + unit + '</text>';
  }
  function drawXAxis(points) {
    var holder = document.querySelector('#chart .c-xlabels');
    if (!holder) return;
    if (!points.length) { holder.innerHTML = ''; return; }
    var W = PLOT.vw - PLOT.left - PLOT.right, y = PLOT.vh - PLOT.bottom + 24, steps = 5, out = '';
    for (var i = 0; i <= steps; i++) {
      var idx = Math.round((i / steps) * (points.length - 1));
      var t = points[idx] && points[idx].time;
      if (!t) continue;
      var label = new Date(t).toLocaleTimeString('ro-RO', { hour: '2-digit', minute: '2-digit' });
      var x = PLOT.left + (i / steps) * W;
      var anchor = i === 0 ? 'start' : (i === steps ? 'end' : 'middle');
      out += '<text fill="#8fb0cc" font-size="11" font-family="Consolas, monospace" x="' + x.toFixed(1) + '" y="' + y + '" text-anchor="' + anchor + '">' + label + '</text>';
    }
    holder.innerHTML = out;
  }
  function drawChart() {
    var points = (dataCache && dataCache.history) || [];
    var pendingEl = $('chart-pending');
    if (pendingEl) pendingEl.hidden = !(dataCache && dataCache.historyPending && points.length < 2);
    var cfg = chartConfig[activeChart];
    var r = valueRange(points, cfg.keys);
    drawGrid(r.min, r.max, cfg.unit);
    var rl = $('chart-range'); if (rl) rl.textContent = range;
    $('chart-title').textContent = cfg.title;
    $('c-a').setAttribute('points', makePoints(points, cfg.keys[0], r.min, r.max));
    $('c-b').setAttribute('points', makePoints(points, cfg.keys[1], r.min, r.max));
    $('c-c').setAttribute('points', makePoints(points, cfg.keys[2], r.min, r.max));
    $('c-area').setAttribute('d', makeArea(points, cfg.keys[0], r.min, r.max));
    drawXAxis(points);
    var legend = $('chart-legend');
    if (legend) {
      legend.innerHTML = cfg.labels.map(function (label, idx) {
        return '<span class="legend-item" style="display:inline-flex;align-items:center;gap:7px">' +
          '<i style="display:inline-block;width:18px;height:4px;border-radius:2px;background:' + SERIES_COLORS[idx] + '"></i>' +
          '<span>' + label + '</span></span>';
      }).join('');
    }
  }

  // ── Gauges (270°, 0–300 V) ──
  function polar(cx, cy, r, deg) { var a = (deg - 90) * Math.PI / 180; return { x: cx + r * Math.cos(a), y: cy + r * Math.sin(a) }; }
  function arc(cx, cy, r, a0, a1) {
    var s = polar(cx, cy, r, a1), e = polar(cx, cy, r, a0);
    var large = a1 - a0 <= 180 ? '0' : '1';
    return ['M', s.x.toFixed(2), s.y.toFixed(2), 'A', r, r, 0, large, 0, e.x.toFixed(2), e.y.toFixed(2)].join(' ');
  }
  function setGauge(idLine, idText, value) {
    var v = clean('voltage', value);
    var path = $(idLine), txt = $(idText);
    if (txt) txt.textContent = v === null ? '--' : fmt(v, 0);
    if (!path) return;
    if (v === null) { path.setAttribute('d', ''); return; }
    var frac = Math.max(0, Math.min(1, v / 300));
    path.setAttribute('d', frac <= 0 ? '' : arc(60, 60, 44, 225, 225 + frac * 270));
  }

  // ── Curent bars (0–100 A, scală vizuală până la 50 A) ──
  function setCurrent(idVal, idBar, value) {
    var v = clean('current', value);
    setText(idVal, v, 2);
    var bar = $(idBar);
    if (bar) bar.style.width = (v === null ? 0 : Math.max(2, Math.min(100, (v / 50) * 100))) + '%';
  }

  // ── Render ──
  function updateLive(d) {
    var live = (d && d.live) || {};
    var u = live.voltage || {}, i = live.current || {}, p = live.power || {};

    setText('pw-l1', clean('power_l1', p.l1), 0);
    setText('pw-l2', clean('power_l2', p.l2), 0);
    setText('pw-l3', clean('power_l3', p.l3), 0);
    setText('pw-total', clean('power_total', p.total), 0);
    setText('now-total', clean('power_total', p.total), 0);

    setGauge('g-v-l1', 'g-t-l1', u.l1);
    setGauge('g-v-l2', 'g-t-l2', u.l2);
    setGauge('g-v-l3', 'g-t-l3', u.l3);

    setCurrent('cur-l1', 'cb-l1', i.l1);
    setCurrent('cur-l2', 'cb-l2', i.l2);
    setCurrent('cur-l3', 'cb-l3', i.l3);

    var when = d && d.updatedAt ? new Date(d.updatedAt) : null;
    var up = $('top-updated');
    if (up) up.textContent = when ? when.toLocaleTimeString('ro-RO') : '--:--:--';
  }

  function setStatus(online) {
    var st = $('top-live'), txt = $('top-live-text'), sideTxt = $('side-status-text'), side = $('side-status');
    if (txt) txt.textContent = online ? 'Live' : 'API indisponibil';
    if (sideTxt) sideTxt.textContent = online ? 'Live' : 'Deconectat';
    if (st) st.classList.toggle('offline', !online);
    if (side) side.classList.toggle('offline', !online);
  }

  var failCount = 0;
  var reqToken = 0; // invalidează răspunsurile vechi (ex. când schimbi intervalul)

  function loadData() {
    var myToken = ++reqToken;
    var ctrl = new AbortController();
    var killer = setTimeout(function () { ctrl.abort(); }, 12000); // timeout dur
    fetch(API + '?range=' + encodeURIComponent(range), { cache: 'no-store', signal: ctrl.signal })
      .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
      .then(function (d) {
        if (myToken !== reqToken) return; // a venit între timp un request mai nou
        dataCache = d;
        updateLive(d); drawChart();
        updateBusiness(d); updateDataQuality(d); updateAnomaly(d);
        failCount = 0; setStatus(true);
      })
      .catch(function (err) {
        if (myToken !== reqToken) return; // ignorăm erorile request-urilor depășite
        failCount++;
        // o eroare izolată nu strică UI-ul; marcăm „indisponibil" doar după 2 la rând
        if (failCount >= 2) setStatus(false);
        console.warn('Dashboard API error', err);
      })
      .finally(function () { clearTimeout(killer); });
  }

  // ── Controls ──
  document.querySelectorAll('.range-select button').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.range-select button').forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      range = btn.getAttribute('data-range') || '12h';
      loadData();
    });
  });
  document.querySelectorAll('.chart-tabs button').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.chart-tabs button').forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      activeChart = btn.getAttribute('data-chart') || 'voltage';
      drawChart();
    });
  });

  // ── Navigație între secțiuni + animație de intrare ──
  var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function playEnter(view) {
    if (!view || reduceMotion) return;
    var items = view.querySelectorAll('[data-anim]');
    items.forEach(function (el, idx) {
      el.style.animation = 'none';
      void el.offsetWidth; // forțăm reflow ca animația să repornească
      el.style.animation = 'viewIn 0.55s cubic-bezier(0.16,1,0.3,1) both';
      el.style.animationDelay = Math.min(idx * 70, 480) + 'ms';
    });
  }

  function switchView(id) {
    var target = document.getElementById('view-' + id);
    if (!target) return;
    document.querySelectorAll('[data-view-panel]').forEach(function (s) {
      s.classList.toggle('active', s === target);
      s.hidden = s !== target;
    });
    document.querySelectorAll('.side-nav .side-link').forEach(function (b) {
      b.classList.toggle('active', b.getAttribute('data-view') === id);
    });
    var btn = document.querySelector('.side-nav .side-link[data-view="' + id + '"]');
    if (btn) {
      var t = $('view-title'), sub = $('view-sub');
      if (t) t.textContent = btn.getAttribute('data-title') || '';
      if (sub) sub.textContent = btn.getAttribute('data-sub') || '';
    }
    // controalele de interval/live sunt relevante doar pe secțiunea „energie"
    var tc = $('top-controls');
    if (tc) tc.style.display = (id === 'energy') ? '' : 'none';
    document.querySelector('.dash-scroll').scrollTop = 0;
    playEnter(target);
  }

  document.querySelectorAll('.side-nav .side-link').forEach(function (btn) {
    btn.addEventListener('click', function () { switchView(btn.getAttribute('data-view')); });
  });

  // ── Start ──
  loadData();
  timer = window.setInterval(loadData, REFRESH_MS);
  playEnter(document.getElementById('view-energy')); // animație la prima încărcare

  // Tabelul de rapoarte are propriul ritm (mai rar) și surse proprii (24h + 7d)
  loadReports();
  window.setInterval(loadReports, 30000);
})();
</script>

<style>
  /* ── Layout shell ── */
  .dash {
    display: grid;
    grid-template-columns: 230px 1fr;
    min-height: 100vh;
    background:
      radial-gradient(1200px 600px at 80% -10%, rgba(6,182,212,0.05), transparent 60%),
      var(--bg);
    color: var(--text);
  }

  /* ── Sidebar ── */
  .dash-sidebar {
    display: flex;
    flex-direction: column;
    gap: 22px;
    padding: 20px 16px;
    background: linear-gradient(180deg, #0a1726, #08111d);
    border-right: 1px solid var(--border);
    position: sticky;
    top: 0;
    height: 100vh;
  }
  .brand { display: flex; align-items: center; gap: 11px; padding: 6px 6px 16px; border-bottom: 1px solid var(--border); text-decoration: none; transition: var(--transition); }
  .brand:hover { opacity: 0.82; }
  .brand-mark svg { width: 34px; height: 34px; }
  .brand-text { display: flex; flex-direction: column; line-height: 1.15; }
  .brand-text strong { font-size: 1rem; font-weight: 800; }
  .brand-text small { font-size: 0.66rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; }

  .side-nav { display: flex; flex-direction: column; gap: 4px; }
  .side-group {
    font-size: 0.62rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--text-dim); padding: 14px 12px 6px;
  }
  .side-group:first-child { padding-top: 4px; }
  .side-link {
    display: flex; align-items: center; gap: 11px; width: 100%; text-align: left;
    padding: 10px 12px; border-radius: var(--radius-sm);
    color: var(--text-muted); font-size: 0.85rem; font-weight: 500; line-height: 1.25;
    background: none; border: 0; cursor: pointer; font-family: inherit;
    position: relative; transition: var(--transition);
  }
  .side-link svg { width: 18px; height: 18px; flex-shrink: 0; }
  .side-link span { min-width: 0; }
  .side-link:hover { background: rgba(16,185,129,0.07); color: var(--text); }
  .side-link.active { background: var(--green-dim); color: var(--green-light); }
  .side-link.active::before { content: ''; position: absolute; left: 0; top: 8px; bottom: 8px; width: 3px; border-radius: 3px; background: var(--green); }

  /* ── Comutare secțiuni ── */
  .view[hidden] { display: none; }
  .view { display: flex; flex-direction: column; gap: 16px; }

  @keyframes viewIn {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: none; }
  }

  /* ── Secțiuni pregătite (preview) ── */
  .ph-hero {
    display: flex; align-items: center; gap: 22px;
