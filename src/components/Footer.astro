---
---
<footer class="site-footer">
  <div class="footer-top-border"></div>
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <div class="footer-logo">
          <svg class="f-logo-icon" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="28" height="28" rx="5" fill="#0d1e30"/>
            <polygon points="17,3 10,15 15,15 11,25 19,13 14,13" fill="#10b981"/>
            <rect x="2" y="12.5" width="5" height="2" rx="1" fill="#06b6d4" opacity="0.8"/>
            <rect x="21" y="12.5" width="5" height="2" rx="1" fill="#06b6d4" opacity="0.8"/>
          </svg>
          <div>
            <span class="f-logo-name">EB104 Lab</span>
            <span class="f-logo-sub">DMAECS</span>
          </div>
        </div>
        <p class="footer-tagline">
          Monitorizare energetică, automatizări și infrastructură locală
          pentru spații tehnice, laboratoare și clădiri.
        </p>
        <div class="footer-badges">
          <span class="tbadge green">100% Local</span>
          <span class="tbadge">Open Source</span>
        </div>
      </div>

      <!-- Links -->
      <div class="footer-col">
        <h4 class="footer-col-title">Servicii</h4>
        <ul class="footer-links">
          <li><a href="#servicii">Monitorizare energetică</a></li>
          <li><a href="#servicii">Automatizări și control</a></li>
          <li><a href="#servicii">Dashboard-uri și rapoarte</a></li>
          <li><a href="#servicii">Hosting local & acces securizat</a></li>
          <li><a href="#servicii">Integrare senzori IoT</a></li>
          <li><a href="#servicii">Mentenanță și extindere</a></li>
        </ul>
      </div>

      <!-- Tech links -->
      <div class="footer-col">
        <h4 class="footer-col-title">Soluții</h4>
        <ul class="footer-links">
          <li><a href="#solutii">Arhitectura sistemului</a></li>
          <li><a href="#proiect">Tablou electric inteligent</a></li>
          <li><a href="#despre">Despre laborator</a></li>
          <li><a href="#tehnologii">Stack tehnic</a></li>
          <li><a href="#pentru-cine">Pentru cine este</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4 class="footer-col-title">Contact</h4>
        <ul class="footer-contacts">
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:contact@eb104lab.ro">contact@eb104lab.ro</a>
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.9 16v.92z"/>
            </svg>
            <a href="tel:+40700000000">+40 XXX XXX XXX</a>
          </li>
          <li class="contact-note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            Luni–Vineri, 09:00–18:00
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} DMAECS-EB104-lab. Toate drepturile rezervate.
      </p>
      <p class="footer-tech-note">
        Construit cu
        <span class="f-tech">Astro</span> ·
        Servit cu
        <span class="f-tech">Nginx</span> ·
        Acces prin
        <span class="f-tech">Cloudflare Tunnel</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg);
    padding: 72px 0 0;
    position: relative;
  }

  .footer-top-border {
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      var(--border-med) 30%,
      var(--border-med) 70%,
      transparent 100%);
    margin-bottom: 72px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr 1.5fr;
    gap: 48px;
    margin-bottom: 60px;
  }

  /* Brand */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 11px;
    margin-bottom: 18px;
  }

  .f-logo-icon { width: 32px; height: 32px; flex-shrink: 0; }

  .f-logo-name {
    display: block;
    font-size: 1rem;
    font-weight: 800;
    color: var(--text);
    line-height: 1.1;
  }

  .f-logo-sub {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--green);
    font-family: 'Courier New', monospace;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.68;
    margin-bottom: 18px;
    max-width: 300px;
  }

  .footer-badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* Columns */
  .footer-col-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--text-dim);
    transition: color 0.18s;
    text-decoration: none;
  }

  .footer-links a:hover { color: var(--green-light); }

  /* Contact list */
  .footer-contacts {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-contacts li {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 0.875rem;
  }

  .footer-contacts svg { color: var(--green); flex-shrink: 0; }

  .footer-contacts a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.18s;
  }

  .footer-contacts a:hover { color: var(--green-light); }

  .contact-note {
    color: var(--text-dim) !important;
    font-size: 0.8rem !important;
  }

  .contact-note svg { color: var(--text-dim) !important; }

  /* Bottom */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 0;
    border-top: 1px solid var(--border);
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .footer-tech-note {
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  .f-tech {
    color: var(--text-muted);
    font-family: 'Courier New', monospace;
    font-weight: 600;
  }

  @media (max-width: 1024px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 36px; }
  }

  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr; gap: 32px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; gap: 8px; }
    .footer-top-border { margin-bottom: 48px; }
  }
</style>
