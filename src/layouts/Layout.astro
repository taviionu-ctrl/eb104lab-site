---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'EB104 Lab — Monitorizare Energetică & Automatizări',
  description = 'Soluții complete pentru monitorizare energetică, automatizări IoT, tablouri electrice inteligente și infrastructură locală. DMAECS-EB104-lab.'
} = Astro.props;
---
<!doctype html>
<html lang="ro">
<head>
  <script is:inline>document.documentElement.classList.add('js');</script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <title>{title}</title>
  <style is:global>
    :root {
      --bg:         #08121e;
      --bg2:        #0b1826;
      --bg3:        #0e1f30;
      --card:       #0d1e30;
      --card-hover: #122436;

      --green:       #10b981;
      --green-light: #34d399;
      --green-dim:   rgba(16,185,129,0.12);
      --cyan:        #06b6d4;
      --cyan-dim:    rgba(6,182,212,0.12);
      --amber:       #f59e0b;
      --amber-dim:   rgba(245,158,11,0.12);
      --red:         #ef4444;

      --border:      rgba(16,185,129,0.12);
      --border-med:  rgba(16,185,129,0.2);
      --border-cyan: rgba(6,182,212,0.2);

      --text:       #e8f0f8;
      --text-muted: #7a9bb8;
      --text-dim:   #3a566e;

      --radius-sm: 6px;
      --radius:    10px;
      --radius-lg: 16px;
      --radius-xl: 22px;

      --transition: all 0.22s cubic-bezier(0.16, 1, 0.3, 1);
      --shadow:     0 4px 24px rgba(0,0,0,0.45);
      --shadow-lg:  0 18px 50px rgba(0,0,0,0.55);

      /* Glassmorphism */
      --glass-bg:     rgba(18, 34, 52, 0.5);
      --glass-border: rgba(180, 220, 255, 0.07);
      --blur:         14px;

      /* Glow */
      --glow-green: 0 0 0 1px rgba(16,185,129,0.18), 0 8px 32px rgba(16,185,129,0.12);
      --glow-cyan:  0 0 0 1px rgba(6,182,212,0.18), 0 8px 32px rgba(6,182,212,0.12);
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html { scroll-behavior: smooth; font-size: 16px; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    /* Aurora de fundal — glow difuz, fix, în spatele conținutului (premium, ieftin) */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: -2;
      pointer-events: none;
      background:
        radial-gradient(900px 520px at 82% -6%, rgba(6,182,212,0.07), transparent 60%),
        radial-gradient(820px 520px at -5% 102%, rgba(16,185,129,0.06), transparent 55%);
    }

    /* Fundal animat — rețea de particule (senzori), fixă, în spate */
    #bg-canvas {
      position: fixed;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      opacity: 0.55;
    }
    @media (prefers-reduced-motion: reduce) { #bg-canvas { display: none; } }

    /* Cifre/date aliniate (tabular) acolo unde folosim monospace */
    code, kbd, samp, .mono, [class*="-val"], [class*="-num"] {
      font-variant-numeric: tabular-nums;
    }

    a { color: inherit; text-decoration: none; }

    img {
      max-width: 100%;
      height: auto;
      display: block;
    }

    /* ─── Container ─── */
    .container {
      max-width: 1240px;
      margin: 0 auto;
      padding: 0 28px;
    }

    @media (max-width: 768px) {
      .container { padding: 0 18px; }
    }

    /* ─── Buttons ─── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 28px;
      border-radius: var(--radius-sm);
      font-size: 0.93rem;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
      border: none;
      text-decoration: none;
      letter-spacing: 0.015em;
      white-space: nowrap;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--green-light) 0%, var(--green) 55%, #0c9b6b 100%);
      color: #04130c;
      box-shadow: 0 2px 14px rgba(16,185,129,0.28), inset 0 1px 0 rgba(255,255,255,0.22);
      position: relative;
      overflow: hidden;
    }
    /* sclipire fină la hover */
    .btn-primary::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(110deg, transparent 30%, rgba(255,255,255,0.35) 50%, transparent 70%);
      transform: translateX(-120%);
      transition: transform 0.6s ease;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(16,185,129,0.42), inset 0 1px 0 rgba(255,255,255,0.25);
    }
    .btn-primary:hover::after { transform: translateX(120%); }

    .btn-secondary {
      background: rgba(255,255,255,0.02);
      color: var(--text);
      border: 1.5px solid var(--border-med);
      backdrop-filter: blur(6px);
    }
    .btn-secondary:hover {
      border-color: var(--green);
      color: var(--green-light);
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(16,185,129,0.14);
    }

    .btn-outline-cyan {
      background: transparent;
      color: var(--cyan);
      border: 1.5px solid var(--border-cyan);
    }
    .btn-outline-cyan:hover {
      background: var(--cyan-dim);
      transform: translateY(-2px);
    }

    /* ─── Section spacing ─── */
    section { padding: 96px 0; }

    @media (max-width: 768px) {
      section { padding: 64px 0; }
    }

    /* ─── Section headings ─── */
    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 0.76rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--green);
      margin-bottom: 14px;
    }
    .section-label::before {
      content: '';
      display: block;
      width: 28px;
      height: 2px;
      background: var(--green);
      flex-shrink: 0;
    }

    .section-title {
      font-size: clamp(1.9rem, 3.8vw, 2.8rem);
      font-weight: 800;
      line-height: 1.12;
      letter-spacing: -0.02em;
      color: var(--text);
      margin-bottom: 18px;
    }

    .section-subtitle {
      font-size: 1.05rem;
      color: var(--text-muted);
      max-width: 620px;
      line-height: 1.72;
    }

    /* ─── Tech badge ─── */
    .tbadge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 11px;
      background: var(--cyan-dim);
      border: 1px solid var(--border-cyan);
      border-radius: 3px;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--cyan);
      font-family: 'Courier New', Consolas, monospace;
      white-space: nowrap;
    }

    .tbadge.green {
      background: var(--green-dim);
      border-color: var(--border-med);
      color: var(--green-light);
    }

    .tbadge.amber {
      background: var(--amber-dim);
      border-color: rgba(245,158,11,0.25);
      color: var(--amber);
    }

    /* ─── Dividers ─── */
    .section-divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 0;
    }

    /* ─── Pulse dot ─── */
    .pulse-dot {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--green);
      box-shadow: 0 0 8px var(--green);
      animation: pulseDot 2.2s infinite;
      flex-shrink: 0;
    }

    @keyframes pulseDot {
      0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--green); }
      50%       { opacity: 0.35; box-shadow: 0 0 3px var(--green); }
    }

    /* ─── Grid texture utility ─── */
    .grid-bg {
      background-image:
        linear-gradient(rgba(16,185,129,0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(16,185,129,0.035) 1px, transparent 1px);
      background-size: 56px 56px;
    }

    /* ─── Glassmorphism ─── */
    .glass {
      background: var(--glass-bg);
      backdrop-filter: blur(var(--blur));
      -webkit-backdrop-filter: blur(var(--blur));
      border: 1px solid var(--glass-border);
    }

    /* ─── Glow orb decorativ (poziționat absolut de componentă) ─── */
    .glow-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(64px);
      opacity: 0.5;
      pointer-events: none;
      z-index: 0;
    }
    .glow-orb.green { background: radial-gradient(circle, rgba(16,185,129,0.5), transparent 70%); }
    .glow-orb.cyan  { background: radial-gradient(circle, rgba(6,182,212,0.45), transparent 70%); }
    .glow-orb.amber { background: radial-gradient(circle, rgba(245,158,11,0.32), transparent 70%); }

    /* ─── Card premium (bază reutilizabilă, hover elegant) ─── */
    .card-premium {
      position: relative;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.025), transparent 40%),
        var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      transition: var(--transition);
      overflow: hidden;
    }
    .card-premium::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 1px;
      background: linear-gradient(135deg, rgba(16,185,129,0.35), transparent 45%);
      -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      opacity: 0;
      transition: opacity 0.3s ease;
      pointer-events: none;
    }
    .card-premium:hover {
      transform: translateY(-4px);
      border-color: var(--border-med);
      box-shadow: var(--shadow-lg), var(--glow-green);
    }
    .card-premium:hover::before { opacity: 1; }

    /* ─── Text cu accent gradient ─── */
    .grad-text {
      background: linear-gradient(120deg, var(--green-light), var(--cyan));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
    }

    @media (prefers-reduced-motion: reduce) {
      .btn-primary::after { display: none; }
    }

    /* ─── Scroll reveal animations ─── */
    .js [data-reveal] {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      will-change: opacity, transform;
    }

    .js [data-reveal].is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Variante de direcție */
    .js [data-reveal="left"]  { transform: translateX(-32px); }
    .js [data-reveal="right"] { transform: translateX(32px); }
    .js [data-reveal="scale"] { transform: scale(0.94); }
    .js [data-reveal="left"].is-visible,
    .js [data-reveal="right"].is-visible,
    .js [data-reveal="scale"].is-visible { transform: none; }

    /* Reduced motion — totul vizibil instant */
    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
      .js [data-reveal] {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
      .pulse-dot { animation: none !important; }
    }

    /* ─── Scrollbar ─── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--bg3); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--green-dim); }
  </style>
</head>
<body>
  <canvas id="bg-canvas" aria-hidden="true"></canvas>
  <slot />

  <!-- Fundal animat: rețea de particule (senzori/date) -->
  <script is:inline>
    (function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var canvas = document.getElementById('bg-canvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var dpr = Math.min(window.devicePixelRatio || 1, 2);
      var W = 0, H = 0, pts = [], maxd = 150, raf = null;

      function build() {
        W = window.innerWidth; H = window.innerHeight;
        canvas.width = W * dpr; canvas.height = H * dpr;
        canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        var count = W < 720 ? 0 : Math.min(86, Math.floor(W / 20));
        pts = [];
        for (var i = 0; i < count; i++) {
          pts.push({ x: Math.random() * W, y: Math.random() * H, vx: (Math.random() - 0.5) * 0.16, vy: (Math.random() - 0.5) * 0.16 });
        }
      }

      function frame() {
        ctx.clearRect(0, 0, W, H);
        for (var i = 0; i < pts.length; i++) {
          var p = pts[i];
          p.x += p.vx; p.y += p.vy;
          if (p.x < 0 || p.x > W) p.vx *= -1;
          if (p.y < 0 || p.y > H) p.vy *= -1;
          ctx.beginPath(); ctx.arc(p.x, p.y, 1.4, 0, 6.2832);
          ctx.fillStyle = 'rgba(52,211,153,0.6)'; ctx.fill();
          for (var j = i + 1; j < pts.length; j++) {
            var q = pts[j], dx = p.x - q.x, dy = p.y - q.y, d = Math.sqrt(dx * dx + dy * dy);
            if (d < maxd) {
              ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(q.x, q.y);
              ctx.strokeStyle = 'rgba(6,182,212,' + (0.16 * (1 - d / maxd)).toFixed(3) + ')';
              ctx.lineWidth = 1; ctx.stroke();
            }
          }
        }
        raf = window.requestAnimationFrame(frame);
      }
      function start() { if (raf) cancelAnimationFrame(raf); frame(); }
      function stop() { if (raf) { cancelAnimationFrame(raf); raf = null; } }

      build(); start();
      var rt;
      window.addEventListener('resize', function () { clearTimeout(rt); rt = setTimeout(function () { build(); }, 200); }, { passive: true });
      document.addEventListener('visibilitychange', function () { document.hidden ? stop() : start(); });
    })();
  </script>

  <script is:inline>
    (function () {
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ─── Scroll reveal ───
      var revealEls = document.querySelectorAll('[data-reveal]');
      if (reduce || !('IntersectionObserver' in window)) {
        revealEls.forEach(function (el) { el.classList.add('is-visible'); });
      } else {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var el = entry.target;
              var delay = parseInt(el.getAttribute('data-delay') || '0', 10);
              setTimeout(function () { el.classList.add('is-visible'); }, delay);
              io.unobserve(el);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        revealEls.forEach(function (el) { io.observe(el); });
      }

      if (reduce) return;

      // ═══ Motor de scroll (rAF) — animații scrubate de scroll ═══
      var clamp = function (v, a, b) { return Math.max(a, Math.min(b, v)); };

      // Hero cinematic (straturi care se mișcă diferit la scroll)
      var hero = document.getElementById('hero');
      var heroText = hero && hero.querySelector('.hero-text');
      var heroMedia = hero && hero.querySelector('.img-frame');
      var orbGreen = hero && hero.querySelector('.glow-orb.green');
      var orbCyan = hero && hero.querySelector('.glow-orb.cyan');

      var parallaxEls = Array.prototype.slice.call(document.querySelectorAll('[data-parallax]'));
      var lines = Array.prototype.slice.call(document.querySelectorAll('[data-progress-line]'));

      var ticking = false;
      function update() {
        var vh = window.innerHeight, sy = window.pageYOffset;

        if (hero) {
          var t = clamp(sy / (vh * 0.85), 0, 1);
          if (heroText) { heroText.style.transform = 'translate3d(0,' + (t * -72).toFixed(1) + 'px,0)'; heroText.style.opacity = (1 - t * 0.92).toFixed(3); }
          if (heroMedia) { heroMedia.style.transform = 'translate3d(0,' + (t * 50).toFixed(1) + 'px,0) scale(' + (1 + t * 0.08).toFixed(3) + ')'; }
          if (orbGreen) orbGreen.style.transform = 'translate3d(0,' + (t * -150).toFixed(1) + 'px,0)';
          if (orbCyan) orbCyan.style.transform = 'translate3d(0,' + (t * 120).toFixed(1) + 'px,0)';
        }

        parallaxEls.forEach(function (el) {
          var rect = el.getBoundingClientRect();
          if (rect.bottom < 0 || rect.top > vh) return;
          var speed = parseFloat(el.getAttribute('data-parallax')) || 0.08;
          var offset = (rect.top + rect.height / 2 - vh / 2) * -speed;
          el.style.transform = 'translate3d(0,' + offset.toFixed(1) + 'px,0)';
        });

        // Timeline: linie de progres care se umple + pași care se activează la scroll
        lines.forEach(function (el) {
          var rect = el.getBoundingClientRect();
          var prog = clamp((vh * 0.62 - rect.top) / (rect.height * 0.72), 0, 1);
          el.style.setProperty('--progress', prog.toFixed(3));
          var steps = el.querySelectorAll('[data-step]');
          for (var i = 0; i < steps.length; i++) {
            var on = prog >= (i + 0.15) / steps.length;
            steps[i].classList.toggle('step-active', on);
          }
        });

        ticking = false;
      }
      window.addEventListener('scroll', function () { if (!ticking) { window.requestAnimationFrame(update); ticking = true; } }, { passive: true });
      window.addEventListener('resize', update, { passive: true });
      update();
    })();
  </script>
</body>
</html>
