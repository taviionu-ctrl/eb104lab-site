---
const categories = [
  {
    name: 'Comunicații & IoT',
    color: 'cyan',
    techs: [
      { name: 'MQTT', desc: 'Broker Mosquitto, protocol IoT lightweight' },
      { name: 'Modbus RTU/TCP', desc: 'Protocol industrial RS485 și Ethernet' },
      { name: 'ESP32', desc: 'Microcontroller WiFi/BT pentru senzori' },
      { name: 'ESPHome', desc: 'Firmware declarativ pentru ESP32/ESP8266' },
    ],
  },
  {
    name: 'Monitorizare & Date',
    color: 'green',
    techs: [
      { name: 'Grafana', desc: 'Dashboard-uri și vizualizare time-series' },
      { name: 'InfluxDB', desc: 'Bază de date optimizată pentru serii temporale' },
      { name: 'Home Assistant', desc: 'Platformă open-source pentru automatizări' },
      { name: 'Node-RED', desc: 'Programare vizuală pentru fluxuri de date' },
    ],
  },
  {
    name: 'Infrastructură locală',
    color: 'amber',
    techs: [
      { name: 'Linux (Debian/Ubuntu)', desc: 'Sistem de operare pentru server local' },
      { name: 'Proxmox VE', desc: 'Virtualizare bare-metal pentru VM și LXC' },
      { name: 'Nginx', desc: 'Reverse proxy și web server' },
      { name: 'Cloudflare Tunnel', desc: 'Acces HTTPS securizat fără IP public' },
    ],
  },
];
---

<section id="tehnologii" class="tech-section grid-bg">
  <div class="tech-glow"></div>
  <div class="container">
    <div class="tech-header">
      <p class="section-label">Stack tehnic</p>
      <h2 class="section-title">Tehnologii deschise,<br>fără vendor lock-in</h2>
      <p class="section-subtitle">
        Folosim exclusiv soluții open-source sau cu licențe permisive, ceea ce înseamnă
        că nu există costuri recurente de licențiere și aveți control complet asupra sistemului.
      </p>
    </div>

    <div class="tech-grid">
      {categories.map(cat => (
        <div class={`tech-cat cat-${cat.color}`}>
          <div class={`cat-header cat-hdr-${cat.color}`}>
            <div class={`cat-indicator ind-${cat.color}`}></div>
            <h3 class="cat-name">{cat.name}</h3>
          </div>
          <div class="tech-items">
            {cat.techs.map(t => (
              <div class={`tech-item item-${cat.color}`}>
                <div class="item-left">
                  <span class={`item-name name-${cat.color}`}>{t.name}</span>
                  <span class="item-desc">{t.desc}</span>
                </div>
                <div class={`item-dot idot-${cat.color}`}></div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Badge cloud -->
    <div class="badge-cloud">
      {['MQTT', 'Modbus RTU', 'Modbus TCP', 'RS485', 'ESP32', 'ESPHome',
        'Grafana', 'InfluxDB', 'Home Assistant', 'Node-RED', 'Mosquitto',
        'Linux', 'Proxmox', 'Nginx', 'Cloudflare Tunnel', 'Let\'s Encrypt',
        'Janitza', 'PZEM-004T', 'SHT31', 'Raspberry Pi'].map(b => (
        <span class="cloud-badge">{b}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .tech-section {
    background: var(--bg);
    position: relative;
    overflow: hidden;
  }

  .tech-glow {
    position: absolute;
    top: 50%; right: -5%;
    width: 50%; height: 60%;
    transform: translateY(-50%);
    background: radial-gradient(ellipse, rgba(16,185,129,0.05) 0%, transparent 65%);
    pointer-events: none;
  }

  .tech-header {
    margin-bottom: 56px;
    max-width: 680px;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 52px;
  }

  /* Category block */
  .tech-cat {
    background: var(--card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    transition: var(--transition);
  }

  .tech-cat:hover {
    border-color: var(--border-med);
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .cat-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 18px;
    border-bottom: 1px solid var(--border);
  }

  .cat-hdr-green { background: rgba(16,185,129,0.06); }
  .cat-hdr-cyan  { background: rgba(6,182,212,0.06); }
  .cat-hdr-amber { background: rgba(245,158,11,0.06); }

  .cat-indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .ind-green { background: var(--green); box-shadow: 0 0 8px rgba(16,185,129,0.5); }
  .ind-cyan  { background: var(--cyan);  box-shadow: 0 0 8px rgba(6,182,212,0.5); }
  .ind-amber { background: var(--amber); box-shadow: 0 0 8px rgba(245,158,11,0.5); }

  .cat-name {
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .tech-items {
    padding: 8px 0;
  }

  .tech-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 18px;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    transition: background 0.15s;
    cursor: default;
  }

  .tech-item:last-child { border-bottom: none; }

  .item-green:hover { background: var(--green-dim); }
  .item-cyan:hover  { background: var(--cyan-dim); }
  .item-amber:hover { background: var(--amber-dim); }

  .item-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .item-name {
    font-size: 0.88rem;
    font-weight: 600;
    font-family: 'Courier New', Consolas, monospace;
  }

  .name-green { color: var(--green-light); }
  .name-cyan  { color: var(--cyan); }
  .name-amber { color: var(--amber); }

  .item-desc {
    font-size: 0.74rem;
    color: var(--text-dim);
    line-height: 1.3;
  }

  .item-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
    opacity: 0.4;
  }

  .idot-green { background: var(--green); }
  .idot-cyan  { background: var(--cyan); }
  .idot-amber { background: var(--amber); }

  /* Badge cloud */
  .badge-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }

  .cloud-badge {
    display: inline-block;
    padding: 6px 13px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-muted);
    font-family: 'Courier New', Consolas, monospace;
    transition: var(--transition);
  }

  .cloud-badge:hover {
    border-color: var(--border-med);
    color: var(--green-light);
    background: var(--green-dim);
  }

  @media (max-width: 900px) {
    .tech-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .tech-header { margin-bottom: 36px; }
    .badge-cloud { gap: 6px; }
    .cloud-badge { font-size: 0.72rem; padding: 5px 10px; }
  }
</style>
