---
const steps = [
  {
    id: '01',
    title: 'Măsurare',
    items: ['Analizor de rețea trifazat', 'Senzori de proces', 'Contoare de energie', 'Citire pe fiecare fază'],
    color: 'cyan',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/><circle cx="12" cy="12" r="1" fill="currentColor"/>
    </svg>`,
  },
  {
    id: '02',
    title: 'Colectare',
    items: ['Comunicație locală securizată', 'Date centralizate într-un loc', 'Fără internet obligatoriu', 'Actualizare continuă'],
    color: 'green',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/>
      <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1"/>
    </svg>`,
  },
  {
    id: '03',
    title: 'Procesare & automatizare',
    items: ['Reguli și automatizări', 'Praguri și condiții logice', 'Reacții în timp real', 'Acțiuni programate'],
    color: 'green',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
    </svg>`,
  },
  {
    id: '04',
    title: 'Istoric',
    items: ['Stocare pe termen lung', 'Retenție configurabilă', 'Backup automat', 'Export pentru rapoarte'],
    color: 'amber',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
      <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
    </svg>`,
  },
  {
    id: '05',
    title: 'Vizualizare',
    items: ['Dashboard în timp real', 'Grafice și evoluții', 'Acces din orice browser', 'Optimizat pentru mobil'],
    color: 'cyan',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
    </svg>`,
  },
  {
    id: '06',
    title: 'Acces & alertare',
    items: ['Acces remote securizat', 'Conexiune criptată', 'Notificări la praguri', 'Rapoarte periodice'],
    color: 'amber',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
    </svg>`,
  },
];
---

<section id="solutii" class="solutions-section grid-bg">
  <div class="container">
    <div class="sol-header" data-reveal>
      <p class="section-label">Cum funcționează</p>
      <h2 class="section-title">Un flux integrat,<br>de la măsurare la decizie</h2>
      <p class="section-subtitle">
        Un sistem complet, care rulează local, pe infrastructura ta. Datele rămân în
        rețeaua internă și pot fi accesate de la distanță doar printr-o conexiune securizată.
      </p>
    </div>

    <!-- Timeline vertical — se animează la scroll -->
    <div class="timeline" data-progress-line>
      <div class="tl-rail"><span class="tl-fill"></span></div>
      {steps.map((step) => (
        <div class={`tl-step tl-${step.color}`} data-step>
          <div class="tl-marker">
            <span class="tl-num">{step.id}</span>
            <div class="tl-icon" set:html={step.icon} />
          </div>
          <div class="tl-card">
            <h4 class="tl-title">{step.title}</h4>
            <ul class="tl-items">
              {step.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom note -->
    <div class="sol-footer" data-reveal>
      <div class="sol-note">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        Întregul sistem rulează local, pe infrastructura ta. Accesul de la distanță se face
        printr-o conexiune criptată, sigură — fără a expune rețeaua direct la internet.
      </div>
    </div>
  </div>
</section>

<style>
  .solutions-section { background: rgba(8,18,30,0.5); }

  .sol-header {
    margin-bottom: 64px;
    max-width: 680px;
  }

  /* ── Timeline vertical scrollytelling ── */
  .timeline {
    position: relative;
    --progress: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  /* rail + fill care urmează scroll-ul (--progress setat din JS) */
  .tl-rail {
    position: absolute;
    left: 27px; top: 18px; bottom: 18px;
    width: 2px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .tl-fill {
    position: absolute;
    left: 0; top: 0; right: 0;
    height: calc(var(--progress, 0) * 100%);
    background: linear-gradient(180deg, var(--green-light), var(--cyan));
    box-shadow: 0 0 12px rgba(16,185,129,0.55);
    transition: height 0.12s linear;
  }

  .tl-step {
    position: relative;
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 18px;
    align-items: start;
    padding: 12px 0;
  }

  /* estompat implicit -> se aprinde la scroll */
  .js .tl-step {
    opacity: 0.36;
    transform: translateX(16px);
    filter: saturate(0.3);
    transition: opacity 0.55s ease, transform 0.55s cubic-bezier(0.16,1,0.3,1), filter 0.55s ease;
  }
  .js .tl-step.step-active { opacity: 1; transform: none; filter: none; }

  .tl-marker {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .tl-num {
    font-size: 0.6rem;
    font-weight: 800;
    font-family: 'Courier New', monospace;
    color: var(--text-dim);
    transition: var(--transition);
  }
  .tl-icon {
    width: 48px; height: 48px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 14px;
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--text-muted);
    transition: var(--transition);
  }
  .tl-icon svg { width: 22px; height: 22px; }

  .tl-green.step-active .tl-icon { color: var(--green-light); border-color: var(--border-med); box-shadow: var(--glow-green); }
  .tl-cyan.step-active  .tl-icon { color: var(--cyan);        border-color: var(--border-cyan); box-shadow: var(--glow-cyan); }
  .tl-amber.step-active .tl-icon { color: var(--amber);       border-color: rgba(245,158,11,0.3); box-shadow: 0 0 0 1px rgba(245,158,11,0.2), 0 8px 28px rgba(245,158,11,0.12); }
  .step-active .tl-num { color: var(--green-light); }

  .tl-card {
    background:
      linear-gradient(180deg, rgba(255,255,255,0.02), transparent 40%),
      var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 18px 22px;
    transition: var(--transition);
  }
  .tl-step.step-active .tl-card { border-color: var(--border-med); box-shadow: var(--shadow); }

  .tl-title { font-size: 1.05rem; font-weight: 700; color: var(--text); margin-bottom: 10px; }
  .tl-items { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 6px 18px; }
  .tl-items li { font-size: 0.84rem; color: var(--text-muted); padding-left: 14px; position: relative; }
  .tl-items li::before { content: '›'; position: absolute; left: 0; color: var(--text-dim); }

  @media (prefers-reduced-motion: reduce) {
    .js .tl-step { opacity: 1 !important; transform: none !important; filter: none !important; }
    .tl-fill { transition: none; }
  }

  @media (max-width: 640px) {
    .tl-items { grid-template-columns: 1fr; }
    .tl-step { gap: 12px; grid-template-columns: 46px 1fr; }
    .tl-rail { left: 22px; }
    .tl-icon { width: 40px; height: 40px; }
  }

  /* Footer note */
  .sol-footer {
    margin-top: 48px;
    display: flex;
    justify-content: center;
  }

  .sol-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    max-width: 700px;
    padding: 16px 22px;
    background: var(--card);
    border: 1px solid var(--border-cyan);
    border-radius: var(--radius);
    font-size: 0.86rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .sol-note svg { color: var(--cyan); flex-shrink: 0; margin-top: 1px; }

</style>
